---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !import.meta.env.PROD || !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const dateFmt = new Intl.DateTimeFormat('en', { dateStyle: 'long' });
---

<BaseLayout title="Posts" description="Technical notes">
  <header class="page-intro">
    <h1>Posts</h1>
    <p>Technical notes on things I figure out at work and in personal projects.</p>
  </header>
  {posts.length === 0 ? (
    <p class="muted">Nothing here yet.</p>
  ) : (
    <ul class="posts">
      {posts.map((post) => (
        <li>
          <time datetime={post.data.date.toISOString()}>{dateFmt.format(post.data.date)}</time>
          <a class="post-title" href={`/posts/${post.id}/`}>
            {post.data.title}
            {post.data.draft && <span class="draft-badge">draft</span>}
          </a>
          <p class="post-desc">{post.data.description}</p>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
