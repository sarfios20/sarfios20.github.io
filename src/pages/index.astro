---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !import.meta.env.PROD || !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
const projects = (await getCollection('projects', ({ data }) => data.featured && (!import.meta.env.PROD || !data.draft)))
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));
const dateFmt = new Intl.DateTimeFormat('en', { dateStyle: 'long' });
---

<BaseLayout title="David Häggström" description="Data engineering, automation and personal projects">
  <section class="hero">
    <p class="kicker">Data engineering · Automation</p>
    <h1>David Häggström Pérez-Flecha</h1>
    <p class="lead">
      Data analyst with a software development background. I build ETL
      pipelines in Python and SQL, automate processes that used to be done by
      hand, and write about what I learn along the way.
    </p>
    <div class="cta-row">
      <a class="button primary" href="/cv/">View CV</a>
      <a class="button" href="https://github.com/sarfios20">GitHub</a>
      <a class="button" href="https://www.linkedin.com/in/david-hpf/">LinkedIn</a>
      <a class="button" href="mailto:davidhaggstromperezflecha@gmail.com">Email</a>
    </div>
  </section>

  <section class="home-section">
    <h2>Featured projects</h2>
    {projects.length === 0 ? (
      <p class="muted">Nothing here yet.</p>
    ) : (
      <ul class="projects">
        {projects.map((project) => (
          <li>
            <h3>{project.data.repo ? <a href={project.data.repo}>{project.data.name}</a> : project.data.name}</h3>
            <p>{project.data.description}</p>
            <p class="meta muted">
              {project.data.repo && <a href={project.data.repo}>Repo</a>}
              {project.data.repo && project.data.year && ' · '}
              {project.data.year && <span>{project.data.year}</span>}
            </p>
          </li>
        ))}
      </ul>
    )}
    <p class="section-more"><a href="/projects/">All projects</a></p>
  </section>

  <section class="home-section">
    <h2>Latest posts</h2>
    {posts.length === 0 ? (
      <p class="muted">Nothing here yet.</p>
    ) : (
      <ul class="posts">
        {posts.map((post) => (
          <li>
            <time datetime={post.data.date.toISOString()}>{dateFmt.format(post.data.date)}</time>
            <a class="post-title" href={`/posts/${post.id}/`}>
              {post.data.title}
            </a>
            <p class="post-desc">{post.data.description}</p>
          </li>
        ))}
      </ul>
    )}
    <p class="section-more"><a href="/posts/">All posts</a></p>
  </section>
</BaseLayout>
