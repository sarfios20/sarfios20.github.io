---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CV" description="CV of David Häggström Pérez-Flecha">
  <header class="page-intro">
    <h1>CV</h1>
    <p>Data Engineering & Automation · Python & SQL · Software Developer</p>
  </header>

  <div class="cta-row">
    <a class="button primary" href="/cv/dhaggstrom_cv.pdf" download>Download PDF</a>
  </div>

  <div class="cv">
    <section>
      <h2>Profile</h2>
      <p>
        Data Analyst with hands-on experience in Python, SQL, automation, and
        ETL pipelines. Built internal tools and data workflows in billing and
        finance environments, with a background in software development and an
        increasing focus on Data Engineering, especially reliable pipelines,
        workflow automation, and data-intensive systems.
      </p>
    </section>

    <section>
      <h2>Experience</h2>

      <div class="cv-role">
        <div class="cv-role-head">
          <h3>Data Analyst</h3>
          <span class="cv-role-meta">Avatel Telecom · Full-time</span>
        </div>
        <p class="cv-role-loc">Oct 2025 – Present · Alcobendas, Madrid, Spain</p>
        <ul>
          <li>Designed and maintained Python-based ETL pipelines over Oracle databases, integrating billing, debt, and customer lifecycle data across multiple legacy systems.</li>
          <li>Built automated workflows replacing manual processes, improving reliability, traceability, and reducing processing times.</li>
          <li>Developed a departmental data mart based on a star schema, providing end-to-end invoice lifecycle visibility and enabling KPI tracking and data-driven decision-making.</li>
          <li>Translated business requirements into technical solutions, collaborating closely with operations teams.</li>
        </ul>
      </div>

      <div class="cv-role">
        <div class="cv-role-head">
          <h3>Technical Analyst</h3>
          <span class="cv-role-meta">Avatel Telecom · Internship</span>
        </div>
        <p class="cv-role-loc">Apr 2025 – Sept 2025 · Alcobendas, Madrid, Spain</p>
        <ul>
          <li>Built data analysis and visualization solutions for the Billing, Debts, and Collections department.</li>
          <li>Built SQL- and Python-based solutions for operational reporting.</li>
          <li>Created automated reporting tools for billing reconciliation with external partners.</li>
        </ul>
      </div>

      <div class="cv-role">
        <div class="cv-role-head">
          <h3>Logistics & Billing Technician</h3>
          <span class="cv-role-meta">PENTEX SL · Freelance</span>
        </div>
        <p class="cv-role-loc">May 2023 – Apr 2025 · Colmenar Viejo, Madrid, Spain</p>
        <ul>
          <li>Built a custom shipping management application to streamline logistics operations.</li>
          <li>Managed invoicing, bank reconciliations, and operational reporting.</li>
          <li>Drove digitalization and process automation initiatives to improve efficiency.</li>
        </ul>
      </div>

      <div class="cv-role">
        <div class="cv-role-head">
          <h3>Data Visualization Intern</h3>
          <span class="cv-role-meta">inBiot Monitoring · Internship</span>
        </div>
        <p class="cv-role-loc">Apr 2022 – Jul 2022 · Remote</p>
        <ul>
          <li>Developed Grafana dashboards for visualizing IoT air quality sensor data.</li>
          <li>Integrated data from REST APIs and managed cloud infrastructure on AWS.</li>
        </ul>
      </div>
    </section>

    <section>
      <h2>Education</h2>
      <div class="cv-role">
        <div class="cv-role-head">
          <h3>Bachelor's Degree in Computer Science</h3>
          <span class="cv-role-meta">Universidad Europea · 2023</span>
        </div>
        <p class="cv-role-loc">
          Software development, programming best practices, algorithms and data
          structures, networking, security, Unix, databases, cloud fundamentals,
          web and app development, software design, and user experience.
        </p>
      </div>
    </section>

    <section>
      <h2>Technical Skills</h2>
      <ul class="cv-skills">
        <li>SQL</li>
        <li>Python</li>
        <li>ETL / Data Pipelines</li>
        <li>Process Automation</li>
        <li>AWS</li>
        <li>REST APIs</li>
        <li>Git</li>
        <li>Linux</li>
        <li>Docker</li>
        <li>JavaScript</li>
        <li>React</li>
        <li>HTML / CSS</li>
      </ul>
    </section>

    <section>
      <h2>Languages</h2>
      <ul class="cv-skills">
        <li>Spanish · Native</li>
        <li>English · Professional</li>
        <li>Swedish · Conversational</li>
      </ul>
    </section>
  </div>
</BaseLayout>
